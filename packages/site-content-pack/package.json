{
  "name": "@ssot-registry/site-content-pack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Product content pack for the SSOT Registry website.",
  "dependencies": {
    "@mdwrk/lander-content-contract": "^0.1.2",
    "@mdwrk/lander-core": "^0.1.2"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "plan:json": "tsx scripts/generate_content_plan_json.ts",
    "plan:xlsx": "npm run plan:json && python scripts/generate_content_plan_xlsx.py",
    "audit": "tsx scripts/generate_site_content_audit.ts",
    "traceability": "tsx scripts/generate_component_traceability.ts",
    "discovery": "tsx scripts/generate_discovery.ts",
    "test": "npm run build && node tests/run-smoke.mjs && npm run audit && node tests/run-audit.mjs && npm run plan:json && node tests/run-plan.mjs && node tests/run-corpus.mjs && npm run traceability && node tests/run-traceability.mjs && npm run discovery && node tests/run-discovery.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles": "./styles/index.css",
    "./styles/*": "./styles/*"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "dist",
    "styles",
    "README.md"
  ],
  "license": "Apache-2.0"
}
