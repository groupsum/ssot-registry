{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ssot-registry/adr.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "id",
    "number",
    "slug",
    "title",
    "status",
    "origin",
    "summary",
    "sections"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "kind": {
      "const": "adr"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "number": {
      "type": "integer",
      "minimum": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "in_review",
        "accepted",
        "rejected",
        "superseded",
        "withdrawn",
        "retired"
      ]
    },
    "origin": {
      "enum": [
        "ssot-core",
        "ssot-origin",
        "repo-local"
      ]
    },
    "decision_date": {
      "type": [
        "string",
        "null"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "superseded_by": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status_notes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sections": {
      "type": "object",
      "required": [
        "decision"
      ],
      "properties": {
        "context": {
          "$ref": "#/$defs/sectionValues"
        },
        "decision": {
          "$ref": "#/$defs/sectionValues"
        },
        "consequences": {
          "$ref": "#/$defs/sectionValues"
        }
      },
      "additionalProperties": {
        "$ref": "#/$defs/sectionValues"
      }
    }
  },
  "$defs": {
    "sectionValues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
