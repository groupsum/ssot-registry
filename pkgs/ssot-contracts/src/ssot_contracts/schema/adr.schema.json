{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ssot-registry/adr.schema.json",
  "$defs": {
    "normalizedId": {
      "type": "string",
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9-]*:[a-z0-9][a-z0-9._-]*$"
    },
    "normalizedIdList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/normalizedId"
      }
    }
  },
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "id",
    "number",
    "slug",
    "title",
    "status",
    "origin",
    "summary",
    "body"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "kind": {
      "const": "adr"
    },
    "id": {
      "$ref": "#/$defs/normalizedId"
    },
    "number": {
      "type": "integer",
      "minimum": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "in_review",
        "accepted",
        "rejected",
        "superseded",
        "withdrawn",
        "retired"
      ]
    },
    "origin": {
      "enum": [
        "ssot-core",
        "ssot-origin",
        "repo-local"
      ]
    },
    "decision_date": {
      "type": [
        "string",
        "null"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "supersedes": {
      "$ref": "#/$defs/normalizedIdList"
    },
    "superseded_by": {
      "$ref": "#/$defs/normalizedIdList"
    },
    "status_notes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "body": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
